      <!-- Bridge -->
      <p begin="00:01:22.000" end="00:01:26.000">
        <span begin="00:01:22.000" end="00:01:23.200">When</span>
        <span begin="00:01:23.200" end="00:01:24.000">the</span>
        <span begin="00:01:24.000" end="00:01:24.800">morning</span>
        <span begin="00:01:24.800" end="00:01:26.000">comes</span>
      </p>
      <p begin="00:01:26.500" end="00:01:30.500">
        <span begin="00:01:26.500" end="00:01:27.500">We will</span>
        <span begin="00:01:27.500" end="00:01:28.500">still</span>
        <span begin="00:01:28.500" end="00:01:29.500">be</span>
        <span begin="00:01:29.500" end="00:01:30.500">here</span>
      </p>
      <p begin="00:01:31.000" end="00:01:35.000">
        <span begin="00:01:31.000" end="00:01:32.000">Holding</span>
        <span begin="00:01:32.000" end="00:01:33.000">on</span>
        <span begin="00:01:33.000" end="00:01:34.000">to</span>
        <span begin="00:01:34.000" end="00:01:35.000">forever</span>
