      </p>
      <p begin="00:00:51.000" end="00:00:55.000">
        <span begin="00:00:51.000" end="00:00:51.800">Hearts</span>
        <span begin="00:00:51.800" end="00:00:52.600">beating</span>
        <span begin="00:00:52.600" end="00:00:53.200">in</span>
        <span begin="00:00:53.200" end="00:00:54.000">perfect</span>
        <span begin="00:00:54.000" end="00:00:55.000">time</span>
      </p>
      <p begin="00:00:55.500" end="00:00:59.500">
        <span begin="00:00:55.500" end="00:00:56.300">Finding</span>
        <span begin="00:00:56.300" end="00:00:57.100">our</span>
        <span begin="00:00:57.100" end="00:00:57.800">way</span>
        <span begin="00:00:57.800" end="00:00:58.600">back</span>
        <span begin="00:00:58.600" end="00:00:59.500">home</span>
      </p>

      <!-- Chorus repeat -->
      <p begin="00:01:01.000" end="00:01:05.500">
        <span begin="00:01:01.000" end="00:01:02.000">Light</span>
        <span begin="00:01:02.000" end="00:01:03.000">up</span>
        <span begin="00:01:03.000" end="00:01:03.800">the</span>
        <span begin="00:01:03.800" end="00:01:05.500">night</span>
      </p>
      <p begin="00:01:05.500" end="00:01:10.000">
        <span begin="00:01:05.500" end="00:01:06.500">We</span>
        <span begin="00:01:06.500" end="00:01:07.500">are</span>
        <span begin="00:01:07.500" end="00:01:08.500">the</span>
