        <span begin="00:00:11.000" end="00:00:11.800">Neon</span>
        <span begin="00:00:11.800" end="00:00:12.600">signs</span>
        <span begin="00:00:12.600" end="00:00:13.200">reflecting</span>
        <span begin="00:00:13.200" end="00:00:14.000">in</span>
        <span begin="00:00:14.000" end="00:00:15.000">puddles</span>
      </p>
      <p begin="00:00:15.500" end="00:00:19.500">
        <span begin="00:00:15.500" end="00:00:16.300">Searching</span>
        <span begin="00:00:16.300" end="00:00:17.100">for</span>
        <span begin="00:00:17.100" end="00:00:17.800">a</span>
        <span begin="00:00:17.800" end="00:00:18.600">place</span>
        <span begin="00:00:18.600" end="00:00:19.500">to belong</span>
      </p>

      <!-- Chorus -->
      <p begin="00:00:21.000" end="00:00:25.500">
        <span begin="00:00:21.000" end="00:00:22.000">Light</span>
        <span begin="00:00:22.000" end="00:00:23.000">up</span>
        <span begin="00:00:23.000" end="00:00:23.800">the</span>
        <span begin="00:00:23.800" end="00:00:25.500">night</span>
      </p>
      <p begin="00:00:25.500" end="00:00:30.000">
        <span begin="00:00:25.500" end="00:00:26.500">We</span>
        <span begin="00:00:26.500" end="00:00:27.500">are</span>
        <span begin="00:00:27.500" end="00:00:28.500">the</span>
        <span begin="00:00:28.500" end="00:00:30.000">dreamers</span>
      </p>
      <p begin="00:00:30.500" end="00:00:35.000">
        <span begin="00:00:30.500" end="00:00:31.500">Dancing</span>
        <span begin="00:00:31.500" end="00:00:32.500">under</span>
        <span begin="00:00:32.500" end="00:00:33.500">the</span>
        <span begin="00:00:33.500" end="00:00:35.000">stars</span>
      </p>
      <p begin="00:00:35.500" end="00:00:40.000">
        <span begin="00:00:35.500" end="00:00:36.500">Nothing</span>
        <span begin="00:00:36.500" end="00:00:37.500">can</span>
        <span begin="00:00:37.500" end="00:00:38.500">stop</span>
        <span begin="00:00:38.500" end="00:00:40.000">us now</span>
      </p>

      <!-- Verse 2 -->
      <p begin="00:00:42.000" end="00:00:46.000">
        <span begin="00:00:42.000" end="00:00:42.800">Whispers</span>
        <span begin="00:00:42.800" end="00:00:43.600">carried</span>
        <span begin="00:00:43.600" end="00:00:44.200">by</span>
        <span begin="00:00:44.200" end="00:00:45.000">the</span>
