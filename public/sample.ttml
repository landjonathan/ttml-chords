  <head>
    <metadata>
      <ttm:title>Sample Lyrics</ttm:title>
    </metadata>
  </head>
  <body>
    <div>
      <!-- Verse 1 -->
      <p begin="00:00:02.000" end="00:00:06.000">
        <span begin="00:00:02.000" end="00:00:02.800">Walking</span>
        <span begin="00:00:02.800" end="00:00:03.400">through</span>
        <span begin="00:00:03.400" end="00:00:04.000">the</span>
        <span begin="00:00:04.000" end="00:00:04.800">city</span>
        <span begin="00:00:04.800" end="00:00:06.000">lights</span>
      </p>
      <p begin="00:00:06.500" end="00:00:10.500">
        <span begin="00:00:06.500" end="00:00:07.300">Every</span>
        <span begin="00:00:07.300" end="00:00:08.100">shadow</span>
        <span begin="00:00:08.100" end="00:00:08.800">tells</span>
        <span begin="00:00:08.800" end="00:00:09.300">a</span>
        <span begin="00:00:09.300" end="00:00:10.500">story</span>
      </p>
